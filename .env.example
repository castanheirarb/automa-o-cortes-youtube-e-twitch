# =============================================
# CANAL CORTE - Variáveis de Ambiente
# =============================================
# Copie este arquivo para .env e preencha com seus dados reais.
# NUNCA commite o arquivo .env no repositório.

# --- TWITCH (para cortes de lives Twitch) ---
TWITCH_CLIENT_ID=seu_client_id_aqui
TWITCH_CLIENT_SECRET=seu_client_secret_aqui

# --- CAMINHOS DOS EXECUTÁVEIS ---
FFMPEG_PATH=
FFPROBE_PATH=
YTDLP_PATH=

# --- CONFIGURAÇÕES DE CORTE ---
OUTPUT_DIR=./output
CLIP_BUFFER_SECONDS=30

# =============================================
# AUTO-POSTER (poster/index.js)
# =============================================

# Modo headless do Playwright
# true  = invisível (produção, computador rodando 24/7)
# false = visível   (use na primeira vez para fazer login manual)
HEADLESS=true

# Habilitar/desabilitar plataformas individualmente
UPLOAD_TO_YOUTUBE=true
UPLOAD_TO_TIKTOK=true

# Horários de postagem (formato cron: 'minuto hora * * *')
CRON_HORARIO_1=0 11 * * *
CRON_HORARIO_2=0 15 * * *
CRON_HORARIO_3=0 19 * * *

# Fuso horário para o agendador
TIMEZONE=America/Sao_Paulo
