# =============================================
# CANAL CORTE - Variáveis de Ambiente
# =============================================
# Copie este arquivo para .env e preencha com seus dados reais.
# NUNCA commite o arquivo .env no repositório.

# --- TWITCH ---
# Obtenha em: https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=seu_client_id_aqui
TWITCH_CLIENT_SECRET=seu_client_secret_aqui

# --- CAMINHOS DOS EXECUTÁVEIS ---
# Se ffmpeg e yt-dlp estiverem no PATH do sistema, deixe em branco.
# Caso contrário, informe o caminho completo do executável.
# Exemplo Windows: C:\ffmpeg\bin\ffmpeg.exe
FFMPEG_PATH=
FFPROBE_PATH=
YTDLP_PATH=

# --- CONFIGURAÇÕES DE SAÍDA ---
# Pasta onde os clipes serão salvos (relativo à raiz do projeto)
OUTPUT_DIR=./output

# Buffer em segundos antes e depois do pico (padrão: 30)
CLIP_BUFFER_SECONDS=30
